# Optional — only needed for "Cloud API" or "Hybrid" analysis mode.
# Tesseract (Offline) mode needs nothing here.
#
# This app works with ANY OpenAI-compatible provider (Groq, OpenAI, OpenRouter,
# Together AI, or a custom endpoint) — pick one in the app's Settings page.
# Setting a key here just pre-fills it on startup so you don't have to paste it
# in every time; you can also skip this file entirely and paste a key directly
# into Settings instead.
CLOUD_API_KEY=your_api_key_here

# Optional: if Tesseract isn't on your PATH, point straight at the binary
# (e.g. C:\Program Files\Tesseract-OCR\tesseract.exe on Windows).
TESSERACT_CMD=
